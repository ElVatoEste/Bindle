# Normalize line endings to LF for text; keep binaries intact.
* text=auto eol=lf

*.go    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.svg   text eol=lf
*.sql   text eol=lf
*.bnd   text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf

*.exe   binary
*.savf  binary
*.png   binary
*.jpg   binary
